<Window x:Class="CodeIsland.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CodeIsland.Desktop"
        Title="CodeIsland"
        Width="620"
        SizeToContent="Height"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <local:StatusBrushConverter x:Key="StatusBrush" />
        <local:StatusBackgroundConverter x:Key="StatusBackground" />
        <local:StatusAccentConverter x:Key="StatusAccent" />
        <Style x:Key="PixelButton" TargetType="Button">
            <Setter Property="Foreground" Value="#F3F6FA" />
            <Setter Property="Background" Value="#202838" />
            <Setter Property="BorderBrush" Value="#45516A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinWidth" Value="32" />
        </Style>
        <Style x:Key="TinyChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="5,1" />
            <Setter Property="Background" Value="#121826" />
        </Style>
        <Style x:Key="SessionTag" TargetType="Border">
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="5,1" />
            <Setter Property="Background" Value="#18202D" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource PixelButton}">
            <Setter Property="Background" Value="#111722" />
            <Setter Property="BorderBrush" Value="#2A3446" />
            <Setter Property="Padding" Value="7,4" />
        </Style>
        <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource PixelButton}">
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="MinWidth" Value="74" />
        </Style>
        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="Background" Value="#090D14" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="#1D2635" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Border x:Name="IslandRoot" Background="#000000" CornerRadius="0,0,22,22" BorderBrush="#191F2A" BorderThickness="1" Padding="0" MouseLeftButtonDown="Window_MouseLeftButtonDown" MouseEnter="IslandRoot_MouseEnter" MouseLeave="IslandRoot_MouseLeave">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#000000" Opacity="0.55" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="CompactBar" Padding="8,4" Background="#000000" CornerRadius="0,0,20,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="MascotShell" Width="32" Height="32" Background="#07090D" CornerRadius="6" Padding="3" Margin="0,0,8,0" BorderBrush="#141B26" BorderThickness="1">
                        <Image x:Name="MascotImage" Source="mascot-codex.gif" Stretch="Uniform" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" x:Name="CompactTextStack">
                        <StackPanel Orientation="Horizontal" x:Name="CompactTitleRow">
                            <Image x:Name="SourceIconImage" Width="13" Height="13" Margin="0,1,5,0" Stretch="Uniform" />
                            <TextBlock x:Name="TitleText" Text="CodeIsland" Foreground="#F3F6FA" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <TextBlock x:Name="SubtitleText" Text="Waiting for AI agent events" Foreground="#9AA3B2" FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,0,0,0" />
                        <StackPanel x:Name="CompactChips" Orientation="Horizontal" Margin="0,3,0,0">
                            <Border Style="{StaticResource TinyChip}" Margin="0,0,5,0">
                                <TextBlock x:Name="SourceTagText" Text="codex" Foreground="#9FB7FF" FontSize="9" FontWeight="SemiBold" />
                            </Border>
                            <Border x:Name="StatusChip" Style="{StaticResource TinyChip}" Margin="0,0,5,0">
                                <TextBlock x:Name="StatusTagText" Text="Idle" Foreground="#62D394" FontSize="9" FontWeight="SemiBold" />
                            </Border>
                            <Border x:Name="StatsChip" Style="{StaticResource TinyChip}" Visibility="Collapsed">
                                <TextBlock x:Name="StatsText" Text="0 sessions / 0 tools" Foreground="#7D8796" FontSize="10" FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock x:Name="CompactToolText" Grid.Column="1" Text="idle" Foreground="#55D66B" FontFamily="Consolas" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Visibility="Collapsed" TextTrimming="CharacterEllipsis" />

                    <StackPanel x:Name="HeaderButtons" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Visibility="Collapsed">
                        <Button Content="Hooks" Style="{StaticResource GhostButton}" Margin="0,0,6,0" Click="InstallHooks_Click" />
                        <Button Content="Settings" Style="{StaticResource GhostButton}" Margin="0,0,6,0" Click="Settings_Click" />
                        <Button Content="-" Style="{StaticResource GhostButton}" Width="30" Click="Hide_Click" />
                    </StackPanel>
                    <Border x:Name="StatusRail" Grid.ColumnSpan="3" Height="2" VerticalAlignment="Bottom" Margin="8,0,8,-4" Background="#223047" CornerRadius="2" Opacity="0.8">
                        <Border x:Name="StatusRailFill" HorizontalAlignment="Left" Width="92" Background="#55D66B" CornerRadius="2" />
                    </Border>
                </Grid>
            </Border>

            <Border x:Name="BlockingPanel" Grid.Row="1" Margin="10,8,10,0" Padding="0" Style="{StaticResource PanelCard}" Visibility="Collapsed">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="22" Height="22" CornerRadius="5" Background="#2C2117" BorderBrush="#8B5E2F" BorderThickness="1" Margin="0,0,8,0">
                            <TextBlock x:Name="BlockingGlyph" Text="!" Foreground="#FFD080" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="BlockingTitle" Foreground="#FFD080" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="BlockingSubtitle" Foreground="#7D8796" FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,1,0,0" />
                        </StackPanel>
                        <Border Grid.Column="2" Style="{StaticResource TinyChip}" VerticalAlignment="Top" Margin="8,0,0,0">
                            <TextBlock x:Name="BlockingQueueText" Foreground="#8D97A8" FontSize="9" FontWeight="SemiBold" />
                        </Border>
                    </Grid>
                    <Border x:Name="BlockingDetailShell" Grid.Row="1" Background="#111722" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                        <TextBlock x:Name="BlockingDetail" Foreground="#CCD4E0" TextWrapping="Wrap" MaxHeight="92" FontFamily="Consolas" FontSize="10" />
                    </Border>
                    <ItemsControl x:Name="QuestionOptionsList" Grid.Row="2" Margin="0,0,0,8" Visibility="Collapsed">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" Style="{StaticResource GhostButton}" HorizontalAlignment="Left" Margin="0,0,6,6" Click="QuestionOption_Click" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBox x:Name="QuestionAnswerBox" Visibility="Collapsed" Margin="0,0,0,8" Background="#111722" Foreground="#F3F6FA" BorderBrush="#45516A" CaretBrush="#F3F6FA" KeyDown="QuestionAnswerBox_KeyDown" />
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="DenyButton" Content="Deny" Style="{StaticResource GhostButton}" Background="#2B1212" BorderBrush="#7D3838" Margin="0,0,6,0" Click="Deny_Click" />
                            <Button x:Name="AlwaysButton" Content="Always" Style="{StaticResource GhostButton}" Background="#16213A" BorderBrush="#3D5D9A" Margin="0,0,6,0" Click="Always_Click" />
                            <Button x:Name="ApproveButton" Content="Allow Once" Style="{StaticResource PrimaryActionButton}" Background="#1E5D2A" BorderBrush="#55B865" Margin="0,0,6,0" Click="Approve_Click" />
                            <Button x:Name="AnswerButton" Content="Send" Style="{StaticResource PrimaryActionButton}" Background="#24477D" BorderBrush="#477AD1" Visibility="Collapsed" Click="Answer_Click" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Grid x:Name="ExpandedPanel" Grid.Row="2" Margin="12,8,12,12" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="CompletionPanel" Style="{StaticResource PanelCard}" Padding="9" Margin="0,0,0,8" Visibility="Collapsed" Opacity="0">
                    <StackPanel>
                        <Grid Margin="0,0,0,7">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="8" Height="8" CornerRadius="4" Background="#62D394" Margin="0,4,7,0" />
                                <TextBlock Text="Completed" Foreground="#62D394" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                            <Button Content="Clear" Style="{StaticResource GhostButton}" HorizontalAlignment="Right" Padding="7,3" Click="ClearCompletions_Click" />
                        </Grid>
                        <ItemsControl x:Name="CompletionCardsList" ItemsSource="{Binding CompletionCards}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#06090E" CornerRadius="7" Padding="8" Margin="0,0,0,6" BorderBrush="#172033" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="28" Height="28" Background="#05070B" CornerRadius="6" Padding="4" Margin="0,0,8,0">
                                                <Image Source="{Binding MascotPath}" Stretch="Uniform" />
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="{Binding SourceIconPath}" Width="13" Height="13" Stretch="Uniform" Margin="0,1,5,0" />
                                                    <TextBlock Text="{Binding Title}" Foreground="#F3F6FA" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="done" Foreground="#62D394" FontSize="10" FontWeight="SemiBold" Margin="6,2,0,0" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Detail}" Foreground="#B8C2D1" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" MaxHeight="38" Margin="0,3,0,0" />
                                                <TextBlock Text="{Binding MetaText}" Foreground="#697486" FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="8,0,0,0">
                                                <Button Content="Jump" Style="{StaticResource GhostButton}" Padding="7,3" Margin="0,0,5,0" Click="CompletionJump_Click" />
                                                <Button Content="x" Style="{StaticResource GhostButton}" Width="28" Padding="4,3" Click="DismissCompletion_Click" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <ItemsControl x:Name="SessionsList" Grid.Row="1" ItemsSource="{Binding Sessions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Status, Converter={StaticResource StatusBackground}}" CornerRadius="8" Padding="8" Margin="0,0,0,6" BorderBrush="#242A36" BorderThickness="1" MouseLeftButtonUp="SessionItem_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="3" Background="{Binding Status, Converter={StaticResource StatusAccent}}" CornerRadius="2" Margin="0,2,8,2" />
                                    <Border Grid.Column="1" Width="30" Height="30" Background="#0B0F16" CornerRadius="7" Padding="4" Margin="0,0,8,0">
                                        <Image Source="{Binding MascotPath}" Stretch="Uniform" />
                                    </Border>
                                    <StackPanel Grid.Column="2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding SourceIconPath}" Width="14" Height="14" Stretch="Uniform" Margin="0,1,5,0" />
                                            <TextBlock Text="{Binding DisplayName}" Foreground="#F3F6FA" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text=" #" Foreground="#7D8796" FontSize="11" Margin="5,1,0,0" />
                                            <TextBlock Text="{Binding ShortId}" Foreground="#7D8796" FontSize="11" Margin="0,1,0,0" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Border Style="{StaticResource SessionTag}">
                                                    <TextBlock Text="{Binding ModelBadge}" Foreground="#8FB0FF" FontSize="9" FontWeight="SemiBold" />
                                                </Border>
                                                <Border Style="{StaticResource SessionTag}">
                                                    <TextBlock Text="{Binding PermissionBadge}" Foreground="#FFD080" FontSize="9" FontWeight="SemiBold" />
                                                </Border>
                                                <Border Style="{StaticResource SessionTag}">
                                                    <TextBlock Text="{Binding SubagentBadge}" Foreground="#BFA6FF" FontSize="9" FontWeight="SemiBold" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="$" Foreground="#55D66B" FontFamily="Consolas" FontWeight="Bold" FontSize="11" Margin="0,0,5,0" />
                                            <TextBlock Text="{Binding ActivityLine}" Foreground="#AEB7C6" FontFamily="Consolas" FontSize="11" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding RecentMessages}" Margin="0,5,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                                        <TextBlock Text="{Binding Prefix}" Foreground="#7D8796" FontFamily="Consolas" FontSize="10" FontWeight="Bold" Width="18" />
                                                        <TextBlock Text="{Binding Text}" Foreground="#CCD4E0" FontFamily="Consolas" FontSize="10" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <ItemsControl ItemsSource="{Binding ToolHistory}" Margin="0,5,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,1,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="34" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="54" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding StatusGlyph}" Foreground="#62D394" FontFamily="Consolas" FontSize="9" FontWeight="Bold" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Summary}" Foreground="#8D97A8" FontFamily="Consolas" FontSize="9" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="2" Text="{Binding TimeText}" Foreground="#667184" FontFamily="Consolas" FontSize="9" HorizontalAlignment="Right" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="{Binding CwdDisplay}" Foreground="#667184" FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Border Background="#18202D" CornerRadius="3" Padding="6,2" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding SourceDisplay}" Foreground="#9FB7FF" FontSize="10" FontWeight="SemiBold" />
                                        </Border>
                                        <TextBlock Text="{Binding StatusText}" Foreground="{Binding Status, Converter={StaticResource StatusBrush}}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding ToolCountText}" Foreground="#7D8796" FontSize="10" HorizontalAlignment="Right" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border x:Name="EmptyState" Grid.Row="2" Background="#0E141D" CornerRadius="9" Padding="12" Visibility="Visible" BorderBrush="#202838" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Image Source="logo.png" Width="28" Height="28" Margin="0,0,10,0" />
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="CodeIsland for Windows" Foreground="#F3F6FA" FontSize="13" FontWeight="SemiBold" />
                            <TextBlock Text="Named pipe: \\.\pipe\codeisland" Foreground="#8D97A8" FontSize="11" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
