<Window
    x:Class="CodeIsland.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CodeIsland.WinUI.Models"
    Title="CodeIsland">

    <Grid Padding="18" Background="#111318">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Text="CodeIsland for Windows" Foreground="#F3F6FA" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="Listening on named pipe: \\.\pipe\codeisland" Foreground="#99A3B3" FontSize="12" />
            </StackPanel>
            <Button Grid.Column="1" Content="Install hooks" Click="InstallHooks_Click" />
        </Grid>

        <Border x:Name="BlockingPanel" Grid.Row="1" Margin="0,14,0,0" Padding="12" Background="#2A2130" CornerRadius="8" Visibility="Collapsed">
            <StackPanel Spacing="10">
                <TextBlock x:Name="BlockingTitle" Foreground="#F3F6FA" FontWeight="SemiBold" />
                <TextBlock x:Name="BlockingDetail" Foreground="#CCD4E0" TextWrapping="Wrap" />
                <TextBox x:Name="QuestionAnswerBox" PlaceholderText="Answer" Visibility="Collapsed" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="ApproveButton" Content="Allow" Click="Approve_Click" />
                    <Button x:Name="AlwaysButton" Content="Always" Click="Always_Click" />
                    <Button x:Name="DenyButton" Content="Deny" Click="Deny_Click" />
                    <Button x:Name="AnswerButton" Content="Send" Click="Answer_Click" Visibility="Collapsed" />
                </StackPanel>
            </StackPanel>
        </Border>

        <ListView Grid.Row="2" Margin="0,18,0,12" ItemsSource="{x:Bind Store.Sessions, Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:SessionState">
                    <Grid Padding="12" Margin="0,0,0,8" Background="#1B1F29" CornerRadius="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}" Foreground="#F3F6FA" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind Source, Mode=OneWay}" Foreground="#9FB7FF" FontSize="12" />
                            <TextBlock Text="{x:Bind CurrentTool, Mode=OneWay}" Foreground="#CCD4E0" FontSize="12" />
                            <TextBlock Text="{x:Bind Cwd, Mode=OneWay}" Foreground="#7D8796" FontSize="11" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="4">
                            <TextBlock Text="{x:Bind StatusText, Mode=OneWay}" Foreground="#62D394" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right" />
                            <TextBlock Text="{x:Bind LastEvent, Mode=OneWay}" Foreground="#AEB7C6" FontSize="11" HorizontalAlignment="Right" />
                            <TextBlock Text="{x:Bind ToolCallCount, Mode=OneWay}" Foreground="#7D8796" FontSize="11" HorizontalAlignment="Right" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock x:Name="FooterText" Grid.Row="3" Foreground="#99A3B3" FontSize="12" />
    </Grid>
</Window>